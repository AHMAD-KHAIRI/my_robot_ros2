<launch>
    <let name="urdf_path" 
        value="$(find-pkg-share my_robot_description)/urdf/my_robot.urdf.xacro" />
        <!-- value="$(find-pkg-share my_robot_description)/urdf/standalone_arm.urdf.xacro" /> -->

    <let name="gazebo_config_path"
         value="$(find-pkg-share my_robot_bringup)/config/gazebo_bridge.yaml" />
    <!-- Note: 10 April 2026 Removed below from gazebo_bridge.yaml 
    - ros_topic_name: "/tf"
      gz_topic_name: "/model/my_robot/tf"
      ros_type_name: "tf2_msgs/msg/TFMessage"
      gz_type_name: "gz.msgs.Pose_V"
      direction: GZ_TO_ROS -->

    <let name="rviz_config_path"
        value="$(find-pkg-share my_robot_description)/rviz/urdf_config.rviz" />

    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description" 
               value="$(command 'xacro $(var urdf_path)')" />
        <param name="use_sim_time" value="true"/>
    </node>

    <!-- gazebo -->
    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="$(find-pkg-share my_robot_bringup)/worlds/test_world.sdf -r" />
        <!-- <arg name="gz_args" value="empty.sdf -r" /> -->
    </include>
    
    <node pkg="ros_gz_sim" exec="create"
          args="-topic robot_description" />

    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var gazebo_config_path)" />
    </node>

    <!-- ros2_control -->
    <!-- <node pkg="controller_manager" exec="ros2_control_node">
        <param name="robot_description" 
               value="$(command 'xacro $(var urdf_path)')" />
        <param from="$(find-pkg-share my_robot_bringup)/config/my_robot_controllers.yaml"/>
    </node> -->

    <node pkg="controller_manager" exec="spawner"
        args="joint_state_broadcaster --controller-manager /controller_manager"/>

    <node pkg="controller_manager" exec="spawner"
        args="diff_drive_controller --controller-manager /controller_manager"/>

    <node pkg="controller_manager" exec="spawner"
        args="arm_joints_controller --controller-manager /controller_manager"/>

    <node pkg="controller_manager" exec="spawner"
        args="gripper_joints_controller --controller-manager /controller_manager"/>

    <!-- rviz -->
    <node pkg="rviz2" exec="rviz2" output="screen"
          args="-d $(var rviz_config_path)">
        <param name="use_sim_time" value="true"/>
    </node>
</launch>