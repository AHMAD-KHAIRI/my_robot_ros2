<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="arm_base_length" value="0.4" />
    <xacro:property name="arm_base_width" value="0.4" />
    <xacro:property name="arm_base_height" value="0.1" />
    <xacro:property name="shoulder_radius" value="0.1" />
    <xacro:property name="shoulder_length" value="0.5" />
    <xacro:property name="arm_radius" value="0.05" />
    <xacro:property name="arm_length" value="0.6" />
    <xacro:property name="elbow_radius" value="0.05" />
    <xacro:property name="elbow_length" value="0.1" />
    <xacro:property name="forearm_radius" value="0.05" />
    <xacro:property name="forearm_length" value="0.5" />
    <xacro:property name="wrist_length" value="0.1" />
    <xacro:property name="wrist_width" value="0.1" />
    <xacro:property name="wrist_height" value="0.05" />
    <xacro:property name="hand_length" value="0.1" />
    <xacro:property name="hand_width" value="0.1" />
    <xacro:property name="hand_height" value="0.02" />


    <link name="arm_base_link">
        <visual>
            <geometry>
                <box size="${arm_base_length} ${arm_base_width} ${arm_base_height}" />
            </geometry>
            <origin xyz="0 0 ${arm_base_height / 2.0}" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <box size="${arm_base_length} ${arm_base_width} ${arm_base_height}" />
            </geometry>
            <origin xyz="0 0 ${arm_base_height / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="5.0" x="${arm_base_length}" y="${arm_base_width}" 
                           z="${arm_base_height}" 
                           o_xyz="0 0 ${arm_base_height / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="shoulder_link">
        <visual>
            <geometry>
                <cylinder length="${shoulder_length}" radius="${shoulder_radius}" />
            </geometry>
            <origin xyz="0 0 ${shoulder_length / 2.0}" rpy="0 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="${shoulder_radius * 2.0} ${shoulder_radius * 2.0} ${shoulder_length}"/>
            </geometry>
            <origin xyz="0 0 ${shoulder_length / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:cylinder_inertia m="10.0" r="${shoulder_radius}" l="${shoulder_length}" 
                                o_xyz="0 0 ${shoulder_length / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="arm_link">
        <visual>
            <geometry>
                <cylinder length="${arm_length}" radius="${arm_radius}" />
            </geometry>
            <origin xyz="0 0 ${arm_length / 2.0}" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <box size="${arm_radius * 2.0} ${arm_radius * 2.0} ${arm_length}" />
            </geometry>
            <origin xyz="0 0 ${arm_length / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:cylinder_inertia m="7.5" r="${arm_radius}" l="${arm_length}" 
                                o_xyz="0 0 ${arm_length / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="elbow_link">
        <visual>
            <geometry>
                <cylinder length="${elbow_length}" radius="${elbow_radius}" />
            </geometry>
            <origin xyz="0 0 ${elbow_length / 2.0}" rpy="0 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="${elbow_radius * 2.0} ${elbow_radius * 2.0} ${elbow_length}" />
            </geometry>
            <origin xyz="0 0 ${elbow_length / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:cylinder_inertia m="2.5" r="${elbow_radius}" l="${elbow_length}" 
                                o_xyz="0 0 ${elbow_length / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="forearm_link">
        <visual>
            <geometry>
                <cylinder length="${forearm_length}" radius="${forearm_radius}" />
            </geometry>
            <origin xyz="0 0 ${forearm_length / 2.0}" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <box size="${forearm_radius * 2.0} ${forearm_radius * 2.0} ${forearm_length}" />
            </geometry>
            <origin xyz="0 0 ${forearm_length / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:cylinder_inertia m="7.5" r="${forearm_radius}" l="${forearm_length}" 
                                o_xyz="0 0 ${forearm_length / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="wrist_link">
        <visual>
            <geometry>
                <box size="${wrist_length} ${wrist_width} ${wrist_height}" />
            </geometry>
            <origin xyz="0 0 ${wrist_height / 2.0}" rpy="0 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="${wrist_length} ${wrist_width} ${wrist_height}" />
            </geometry>
            <origin xyz="0 0 ${wrist_height / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="1.5" x="${wrist_length}" y="${wrist_width}" 
                           z="${wrist_height}" 
                           o_xyz="0 0 ${wrist_height / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="hand_link">
        <visual>
            <geometry>
                <box size="${hand_length} ${hand_width} ${hand_height}" />
            </geometry>
            <origin xyz="0 0 ${hand_height / 2.0}" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <box size="${hand_length} ${hand_width} ${hand_height}" />
            </geometry>
            <origin xyz="0 0 ${hand_height / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="0.5" x="${hand_length}" y="${hand_width}" 
                           z="${hand_height}" 
                           o_xyz="0 0 ${hand_height / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="tool_link" />

    <joint name="arm_joint1" type="revolute">
        <parent link="arm_base_link" />
        <child link="shoulder_link" />
        <origin xyz="0 0 0.1" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit effort="1000.0" velocity="1.0" lower="-3.14" upper="3.14" />
        <dynamics damping="5.0" friction="1.0"/>
    </joint>

    <joint name="arm_joint2" type="revolute">
        <parent link="shoulder_link" />
        <child link="arm_link" />
        <origin xyz="0 0 0.5" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="0" upper="2.5" />
        <dynamics damping="5.0" friction="1.0"/>
    </joint>

    <joint name="arm_joint3" type="revolute">
        <parent link="arm_link" />
        <child link="elbow_link" />
        <origin xyz="0 0 0.6" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="0" upper="2.5" />
        <dynamics damping="5.0" friction="1.0"/>
    </joint>

    <joint name="arm_joint4" type="revolute">
        <parent link="elbow_link" />
        <child link="forearm_link" />
        <origin xyz="0 0 0.1" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit effort="1000.0" velocity="1.0" lower="-3.14" upper="3.14" />
        <dynamics damping="5.0" friction="1.0"/>
    </joint>

    <joint name="arm_joint5" type="revolute">
        <parent link="forearm_link" />
        <child link="wrist_link" />
        <origin xyz="0 0 0.5" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="-1.57" upper="1.57" />
        <dynamics damping="5.0" friction="1.0"/>
    </joint>

    <joint name="arm_joint6" type="continuous">
        <parent link="wrist_link" />
        <child link="hand_link" />
        <origin xyz="0 0 0.05" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <dynamics damping="5.0" friction="1.0"/>
    </joint>

    <joint name="arm_hand_tool_joint" type="fixed">
        <parent link="hand_link" />
        <child link="tool_link" />
        <origin xyz="0 0 0.02" rpy="0 0 0" />
    </joint>

</robot>