<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="gripper_base_length" value="0.2" />
    <xacro:property name="gripper_base_width" value="0.06" />
    <xacro:property name="gripper_base_height" value="0.02" />
    <xacro:property name="gripper_left_finger_length" value="0.02" />
    <xacro:property name="gripper_left_finger_width" value="0.06" />
    <xacro:property name="gripper_left_finger_height" value="0.08" />

    <link name="gripper_base_link">
        <visual>
            <geometry>
                <box size="${gripper_base_length} ${gripper_base_width} ${gripper_base_height}" />
            </geometry>
            <origin xyz="0 0 ${gripper_base_height / 2.0}" rpy="0 0 0" />
            <material name="dark_green" />
        </visual>
        <collision>
            <geometry>
                <box size="${gripper_base_length} ${gripper_base_width} ${gripper_base_height}" />
            </geometry>
            <origin xyz="0 0 ${gripper_base_height / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="2.0" x="${gripper_base_length}" y="${gripper_base_width}" 
                           z="${gripper_base_height}" 
                           o_xyz="0 0 ${gripper_base_height / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="gripper_left_finger_link">
        <visual>
            <geometry>
                <box size="${gripper_left_finger_length} ${gripper_left_finger_width} ${gripper_left_finger_height}" />
            </geometry>
            <origin xyz="0 0 ${gripper_left_finger_height / 2.0}" rpy="0 0 0" />
            <material name="light_green" />
        </visual>
        <collision>
            <geometry>
                <box size="${gripper_left_finger_length} ${gripper_left_finger_width} ${gripper_left_finger_height}" />
            </geometry>
            <origin xyz="0 0 ${gripper_left_finger_height / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="0.5" x="${gripper_left_finger_length}" y="${gripper_left_finger_width}" 
                           z="${gripper_left_finger_height}" 
                           o_xyz="0 0 ${gripper_left_finger_height / 2.0}" o_rpy="0 0 0" />
    </link>

    <link name="gripper_right_finger_link">
        <visual>
            <geometry>
                <box size="${gripper_left_finger_length} ${gripper_left_finger_width} ${gripper_left_finger_height}" />
            </geometry>
            <origin xyz="0 0 ${gripper_left_finger_height / 2.0}" rpy="0 0 0" />
            <material name="light_green" />
        </visual>
        <collision>
            <geometry>
                <box size="${gripper_left_finger_length} ${gripper_left_finger_width} ${gripper_left_finger_height}" />
            </geometry>
            <origin xyz="0 0 ${gripper_left_finger_height / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="0.5" x="${gripper_left_finger_length}" y="${gripper_left_finger_width}" 
                           z="${gripper_left_finger_height}" 
                           o_xyz="0 0 ${gripper_left_finger_height / 2.0}" o_rpy="0 0 0" />
    </link>

    <joint name="gripper_left_finger_joint" type="prismatic">
        <parent link="gripper_base_link" />
        <child link="gripper_left_finger_link" />
        <origin xyz="-0.07 0 0.02" rpy="0 0 0" />
        <axis xyz="1 0 0" />
        <limit lower="0.0" upper="0.06" effort="1000" velocity="1.0" />
        <dynamics damping="5.0" friction="1.0"/>
    </joint>

    <joint name="gripper_right_finger_joint" type="prismatic">
        <parent link="gripper_base_link" />
        <child link="gripper_right_finger_link" />
        <origin xyz="0.07 0 0.02" rpy="0 0 0" />
        <axis xyz="1 0 0" />
        <!-- <mimic joint="gripper_left_finger_joint" multiplier="-1.0" /> -->
        <limit lower="-0.06" upper="0.0" effort="1000.0" velocity="1.0" />
        <dynamics damping="5.0" friction="1.0"/>
    </joint>

</robot>