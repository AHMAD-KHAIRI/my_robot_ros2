<?xml version="1.0"?>
<robot name="zoei" xmlns:xacro="http://ros.org/wiki/xacro">

  <link name="base"/>

  <!-- front right laser -->
  <joint name="laser_joint" type="fixed">
    <parent link="base"/>
    <child link="laser_preset"/>
    <origin rpy="${pi} 0 ${-pi/4}" xyz="0.478 -0.243 0.195"/>
  </joint>
  <link name="laser_preset"/>

  <!-- rear left laser -->
  <joint name="laser2_joint" type="fixed">
    <parent link="base"/>
    <child link="laser2_preset"/>
    <origin rpy="${pi} 0 ${pi*3/4}" xyz="-0.478 0.243 0.195"/>
  </joint>
  <link name="laser2_preset"/>

  <!-- front camera -->
  <joint name="laser3_joint" type="fixed">
    <parent link="base"/>
    <child link="laser3_preset"/>
    <origin rpy="${pi} 0 0" xyz="0.55 0 0.233"/>
  </joint>
  <link name="laser3_preset"/>
  <joint name="laser3_link_joint" type="floating">
    <parent link="base"/>
    <child link="laser3"/>
  </joint>
  <link name="laser3"/>
  <joint name="camera1_color_joint" type="fixed">
    <parent link="laser3"/>
    <child link="camera1_color_optical_frame"/>
    <origin rpy="${-pi/2} 0 ${-pi/2}" xyz="0 0 0"/>
  </joint>
  <link name="camera1_color_optical_frame"/>

  <!-- rear camera -->
  <joint name="laser4_joint" type="fixed">
    <parent link="base"/>
    <child link="laser4_preset"/>
    <origin rpy="${pi} 0 ${pi}" xyz="-0.55 0 0.233"/>
  </joint>
  <link name="laser4_preset"/>
  <joint name="laser4_link_joint" type="floating">
    <parent link="base"/>
    <child link="laser4"/>
  </joint>
  <link name="laser4"/>
  <joint name="camera2_color_joint" type="fixed">
    <parent link="laser4"/>
    <child link="camera2_color_optical_frame"/>
    <origin rpy="${-pi/2} 0 ${-pi/2}" xyz="0 0 0"/>
  </joint>
  <link name="camera2_color_optical_frame"/>

  <!-- left camera -->
  <joint name="laser5_joint" type="fixed">
    <parent link="base"/>
    <child link="laser5_preset"/>
    <origin rpy="0 0 ${pi/2}" xyz="0 0.3 0.233"/>
  </joint>
  <link name="laser5_preset"/>
  <joint name="laser5_link_joint" type="floating">
    <parent link="base"/>
    <child link="laser5"/>
  </joint>
  <link name="laser5"/>
  <joint name="camera3_color_joint" type="fixed">
    <parent link="laser5"/>
    <child link="camera3_color_optical_frame"/>
    <origin rpy="${-pi/2} 0 ${-pi/2}" xyz="0 0 0"/>
  </joint>
  <link name="camera3_color_optical_frame"/>

  <!-- right camera -->
  <joint name="laser6_joint" type="fixed">
    <parent link="base"/>
    <child link="laser6_preset"/>
    <origin rpy="0 0 ${-pi/2}" xyz="0 -0.3 0.233"/>
  </joint>
  <link name="laser6_preset"/>
  <joint name="laser6_link_joint" type="floating">
    <parent link="base"/>
    <child link="laser6"/>
  </joint>
  <link name="laser6"/>
  <joint name="camera4_color_joint" type="fixed">
    <parent link="laser6"/>
    <child link="camera4_color_optical_frame"/>
    <origin rpy="${-pi/2} 0 ${-pi/2}" xyz="0 0 0"/>
  </joint>
  <link name="camera4_color_optical_frame"/>

  <!-- front left livox 1.5m hanging laser -->
  <joint name="laser7_joint" type="fixed">
    <parent link="base"/>
    <child link="laser7"/>
    <origin rpy="0 0 0" xyz="0.487 0.252 1.5"/>
  </joint>
  <link name="laser7"/>

  <!-- rear right livox 1.5m hanging laser -->
  <joint name="laser8_joint" type="fixed">
    <parent link="base"/>
    <child link="laser8"/>
    <origin rpy="0 0 0" xyz="-0.487 -0.252 1.5"/>
  </joint>
  <link name="laser8"/>

  <!-- front left livox 3d lidar -->
  <joint name="camera1_joint" type="fixed">
    <parent link="base"/>
    <child link="camera1_preset"/>
    <origin rpy="0 0 ${pi/2}" xyz="0.487 0.252 0.173"/>
  </joint>
  <link name="camera1_preset"/>
  <joint name="camera1_link_joint" type="floating">
    <parent link="base"/>
    <child link="camera1_link"/>
  </joint>
  <link name="camera1_link"/>
  <joint name="camera1_depth_joint" type="fixed">
    <parent link="camera1_link"/>
    <child link="camera1_depth_optical_frame"/>
    <origin rpy="${-pi/2} 0 ${-pi*3/8}" xyz="0 0 0"/>
  </joint>
  <link name="camera1_depth_optical_frame"/>
  <joint name="livox1_depth_joint" type="fixed">
    <parent link="camera1_link"/>
    <child link="livox1_depth_optical_frame"/>
    <origin rpy="${-pi/2} 0 ${pi*7/8}" xyz="0 0 0"/>
  </joint>
  <link name="livox1_depth_optical_frame"/>

  <!-- rear right livox 3d lidar -->
  <joint name="camera2_joint" type="fixed">
    <parent link="base"/>
    <child link="camera2_preset"/>
    <origin rpy="0 0 ${-pi/2}" xyz="-0.487 -0.252 0.173"/>
  </joint>
  <link name="camera2_preset"/>
  <joint name="camera2_link_joint" type="floating">
    <parent link="base"/>
    <child link="camera2_link"/>
  </joint>
  <link name="camera2_link"/>
  <joint name="camera2_depth_joint" type="fixed">
    <parent link="camera2_link"/>
    <child link="camera2_depth_optical_frame"/>
    <origin rpy="${-pi/2} 0 ${-pi*3/8}" xyz="0 0 0"/>
  </joint>
  <link name="camera2_depth_optical_frame"/>
  <joint name="livox2_depth_joint" type="fixed">
    <parent link="camera2_link"/>
    <child link="livox2_depth_optical_frame"/>
    <origin rpy="${-pi/2} 0 ${pi*7/8}" xyz="0 0 0"/>
  </joint>
  <link name="livox2_depth_optical_frame"/>

  <!-- front left livox 0.3m hole laser -->
  <joint name="camera1_scan_joint" type="fixed">
    <parent link="base"/>
    <child link="camera1_scan"/>
    <origin rpy="0 0 0" xyz="0.487 0.252 0.3"/>
  </joint>
  <link name="camera1_scan"/>

  <!-- rear right livox 0.3m hole laser -->
  <joint name="camera2_scan_joint" type="fixed">
    <parent link="base"/>
    <child link="camera2_scan"/>
    <origin rpy="0 0 0" xyz="-0.487 -0.252 0.3"/>
  </joint>
  <link name="camera2_scan"/>

  <!-- imu -->
  <joint name="imu_joint" type="fixed">
    <parent link="base"/>
    <child link="imu_preset"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <link name="imu_preset"/>

</robot>
